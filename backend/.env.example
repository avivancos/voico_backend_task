OPENAI_API_KEY=sk-...
# Bound the in-request OpenAI call: per-request timeout and retry cap (worst case ~timeout*(1+retries)).
OPENAI_TIMEOUT_SECONDS=20
OPENAI_MAX_RETRIES=1
DATABASE_URL=sqlite+aiosqlite:///./db.sqlite3

# Comma-separated CORS allow-list (never "*" with credentials).
ALLOWED_ORIGINS=http://localhost:5173

# Stale-call auto-expiry (Task 3). How often the sweep runs and how long a call may stay
# in_progress before it is force-failed. Lower these (e.g. 0.1) to exercise the job quickly.
EXPIRY_INTERVAL_MINUTES=10
EXPIRY_THRESHOLD_MINUTES=30

# Webhook security (Task 4). Leave WEBHOOK_SECRET empty to accept unsigned webhooks (dev/demo —
# matches the README "Try it out" Swagger flow). Set it to REQUIRE, on every POST /api/webhook/call,
# an HMAC-SHA256 header `X-Signature: sha256=<hex over "{X-Timestamp}.{raw_body}">` plus an
# `X-Timestamp` (Unix seconds) within WEBHOOK_TOLERANCE_SECONDS of now — that is the replay window.
WEBHOOK_SECRET=
WEBHOOK_TOLERANCE_SECONDS=300
