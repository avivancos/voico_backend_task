{
  "components": {
    "schemas": {
      "CallCounts": {
        "properties": {
          "failed": {
            "default": 0,
            "title": "Failed",
            "type": "integer"
          },
          "in_progress": {
            "default": 0,
            "title": "In Progress",
            "type": "integer"
          },
          "success": {
            "default": 0,
            "title": "Success",
            "type": "integer"
          }
        },
        "title": "CallCounts",
        "type": "object"
      },
      "CallLabel": {
        "enum": [
          "Sales inquiry",
          "Support",
          "Complaint",
          "Appointment",
          "Follow-up",
          "Other"
        ],
        "title": "CallLabel",
        "type": "string"
      },
      "CallResponse": {
        "properties": {
          "caller_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Caller Name"
          },
          "created_at": {
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "duration_seconds": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Duration Seconds"
          },
          "ended_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Ended At"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          },
          "label": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/CallLabel"
              },
              {
                "type": "null"
              }
            ]
          },
          "phone_number": {
            "title": "Phone Number",
            "type": "string"
          },
          "raw_transcript": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Raw Transcript"
          },
          "started_at": {
            "format": "date-time",
            "title": "Started At",
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/CallStatus"
          },
          "summary": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Summary"
          },
          "updated_at": {
            "format": "date-time",
            "title": "Updated At",
            "type": "string"
          }
        },
        "required": [
          "id",
          "phone_number",
          "caller_name",
          "duration_seconds",
          "status",
          "summary",
          "label",
          "started_at",
          "ended_at",
          "created_at",
          "updated_at",
          "raw_transcript"
        ],
        "title": "CallResponse",
        "type": "object"
      },
      "CallStatus": {
        "enum": [
          "in_progress",
          "success",
          "failed"
        ],
        "title": "CallStatus",
        "type": "string"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "PaginatedCallsResponse": {
        "properties": {
          "counts": {
            "$ref": "#/components/schemas/CallCounts"
          },
          "data": {
            "items": {
              "$ref": "#/components/schemas/CallResponse"
            },
            "title": "Data",
            "type": "array"
          },
          "page": {
            "title": "Page",
            "type": "integer"
          },
          "page_size": {
            "title": "Page Size",
            "type": "integer"
          },
          "total": {
            "title": "Total",
            "type": "integer"
          },
          "total_pages": {
            "title": "Total Pages",
            "type": "integer"
          }
        },
        "required": [
          "data",
          "total",
          "page",
          "page_size",
          "total_pages",
          "counts"
        ],
        "title": "PaginatedCallsResponse",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      },
      "WebhookCallPayload": {
        "properties": {
          "call_id": {
            "format": "uuid",
            "title": "Call Id",
            "type": "string"
          },
          "duration_seconds": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Duration Seconds"
          },
          "ended_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Ended At"
          },
          "raw_transcript": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Raw Transcript"
          },
          "status": {
            "$ref": "#/components/schemas/CallStatus"
          }
        },
        "required": [
          "call_id",
          "status"
        ],
        "title": "WebhookCallPayload",
        "type": "object"
      }
    }
  },
  "info": {
    "description": "Backend API for the Voico Calls Dashboard.",
    "title": "Voico Calls Dashboard",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/calls": {
      "get": {
        "operationId": "list_calls_api_calls_get",
        "parameters": [
          {
            "in": "query",
            "name": "status",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "$ref": "#/components/schemas/CallStatus"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Status"
            }
          },
          {
            "in": "query",
            "name": "page",
            "required": false,
            "schema": {
              "default": 1,
              "minimum": 1,
              "title": "Page",
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "page_size",
            "required": false,
            "schema": {
              "default": 20,
              "maximum": 100,
              "minimum": 1,
              "title": "Page Size",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedCallsResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "List Calls",
        "tags": [
          "calls"
        ]
      }
    },
    "/api/calls/{call_id}": {
      "get": {
        "operationId": "get_call_api_calls__call_id__get",
        "parameters": [
          {
            "in": "path",
            "name": "call_id",
            "required": true,
            "schema": {
              "format": "uuid",
              "title": "Call Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CallResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Call",
        "tags": [
          "calls"
        ]
      }
    },
    "/api/webhook/call": {
      "post": {
        "operationId": "webhook_call_api_webhook_call_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WebhookCallPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CallResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Webhook Call",
        "tags": [
          "calls"
        ]
      }
    },
    "/health": {
      "get": {
        "description": "Return ``ok`` while the service is running.",
        "operationId": "health_check_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Health Check Health Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Health check",
        "tags": [
          "health"
        ]
      }
    }
  },
  "tags": [
    {
      "description": "List, inspect, annotate, and ingest call records.",
      "name": "calls"
    },
    {
      "description": "Service liveness probe.",
      "name": "health"
    }
  ]
}
